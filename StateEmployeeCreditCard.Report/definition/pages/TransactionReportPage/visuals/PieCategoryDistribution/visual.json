{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.4.0/schema.json",
  "name": "PieCategoryDistribution",
  "position": {
    "x": 40,
    "y": 520,
    "z": 0,
    "width": 460,
    "height": 520,
    "tabOrder": 2
  },
  "visual": {
    "visualType": "pieChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Transactions"
                    }
                  },
                  "Property": "CategoryGroup"
                }
              },
              "queryRef": "Transactions.CategoryGroup",
              "nativeQueryRef": "CategoryGroup",
              "displayName": "Category (Top 5 + Other)"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Transactions"
                    }
                  },
                  "Property": "Total Transaction Volume"
                }
              },
              "queryRef": "Transactions.Total Transaction Volume",
              "nativeQueryRef": "Total Transaction Volume"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Measure": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "Transactions"
                  }
                },
                "Property": "Total Transaction Volume"
              }
            },
            "direction": "Descending"
          }
        ],
        "isDefaultSort": true
      }
    },
    "objects": {
      "legend": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "position": {
              "expr": {
                "Literal": {
                  "Value": "'Bottom'"
                }
              }
            }
          }
        }
      ],
      "labels": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "labelStyle": {
              "expr": {
                "Literal": {
                  "Value": "'Percent of total'"
                }
              }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Transaction Category Distribution'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}
