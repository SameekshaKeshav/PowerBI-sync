{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.6.0/schema.json",
  "name": "LineDeptTrend",
  "position": {
    "x": 990,
    "y": 370,
    "z": 0,
    "width": 890,
    "height": 350,
    "tabOrder": 8
  },
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Date"
                    }
                  },
                  "Property": "YearMonth"
                }
              },
              "queryRef": "Date.YearMonth",
              "nativeQueryRef": "YearMonth",
              "displayName": "Month"
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Transactions"
                    }
                  },
                  "Property": "DeptGroup"
                }
              },
              "queryRef": "Transactions.DeptGroup",
              "nativeQueryRef": "DeptGroup",
              "displayName": "Department (Top 5 + Other)"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Transactions"
                    }
                  },
                  "Property": "Total Transaction Amount"
                }
              },
              "queryRef": "Transactions.Total Transaction Amount",
              "nativeQueryRef": "Total Transaction Amount"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Column": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "Date"
                  }
                },
                "Property": "YearMonth"
              }
            },
            "direction": "Ascending"
          }
        ],
        "isDefaultSort": true
      }
    },
    "objects": {
      "lineStyles": [
        {
          "properties": {
            "strokeWidth": {
              "expr": {
                "Literal": {
                  "Value": "2D"
                }
              }
            },
            "lineChartType": {
              "expr": {
                "Literal": {
                  "Value": "'smooth'"
                }
              }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Transaction Trend by Department (Demographic Proxy)'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}
